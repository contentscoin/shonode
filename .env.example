# Copy this file to `.env` and fill in your Gemini key.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
PORT=4173
# Optional: comma-separated web origins allowed to call /api/storyboard
# SHONODE_ALLOWED_ORIGINS=https://shonode.vercel.app,https://your-domain.com

# Optional: Supabase cloud mode (auth + cloud project storage).
# Leave unset to run Shonode in local-only mode.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
